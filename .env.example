NAVER_OAUTH_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# 카카오 (OAuth + 채널 Public ID, 예: _ZeUTxl)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_CHANNEL_PUBLIC_ID=

# 예약 발행 cron (openssl rand -hex 32)
CRON_SECRET=

# OAuth state 서명
